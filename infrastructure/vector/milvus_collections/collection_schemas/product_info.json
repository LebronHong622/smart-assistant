{
  "collection_name": "product_intro",
  "description": "荣耀商品介绍集合，存储商品基础信息与详细介绍",
  "fields": [
    {
      "name": "id",
      "data_type": "INT64",
      "is_primary": true,
      "auto_id": true,
      "description": "集合主键，自动生成的唯一标识符"
    },
    {
      "name": "product_id",
      "data_type": "VARCHAR",
      "max_length": 20,
      "description": "商品唯一ID（如P001、P002）"
    },
    {
      "name": "name",
      "data_type": "VARCHAR",
      "max_length": 100,
      "description": "商品名称（如荣耀Magic6 Pro）"
    },
    {
      "name": "category",
      "data_type": "VARCHAR",
      "max_length": 64,
      "description": "商品类别"
    },
    {
      "name": "brand",
      "data_type": "VARCHAR",
      "max_length": 50,
      "description": "商品品牌"
    },
    {
      "name": "price",
      "data_type": "DOUBLE",
      "description": "商品价格"
    },
    {
      "name": "tags",
      "data_type": "VARCHAR",
      "max_length": 500,
      "description": "商品标签（逗号分隔）"
    },
    {
      "name": "specifications",
      "data_type": "VARCHAR",
      "max_length": 2000,
      "description": "商品规格参数"
    },
    {
      "name": "key_attributes",
      "data_type": "VARCHAR",
      "max_length": 1000,
      "description": "商品关键属性"
    },
    {
      "name": "sales_count",
      "data_type": "INT64",
      "description": "商品销量"
    },
    {
      "name": "rating",
      "data_type": "FLOAT",
      "description": "商品评分"
    },
    {
      "name": "status",
      "data_type": "VARCHAR",
      "max_length": 20,
      "description": "商品状态（上架/下架/售罄）"
    },
    {
      "name": "created_at",
      "data_type": "VARCHAR",
      "max_length": 32,
      "description": "创建时间"
    },
    {
      "name": "updated_at",
      "data_type": "VARCHAR",
      "max_length": 32,
      "description": "更新时间"
    },
    {
      "name": "content",
      "data_type": "VARCHAR",
      "max_length": 2000,
      "description": "商品详细介绍文本"
    },
    {
      "name": "embedding",
      "data_type": "FLOAT_VECTOR",
      "dim": 768,
      "description": "商品介绍文本的稠密向量表示"
    },
    {
      "name": "sparse_embedding",
      "data_type": "SPARSE_FLOAT_VECTOR",
      "description": "商品介绍文本的稀疏向量表示"
    }
  ],
  "index": {
    "field_name": "embedding",
    "index_type": "IVF_FLAT",
    "metric_type": "L2",
    "params": {
      "nlist": 128
    }
  },
  "sparse_index": {
    "field_name": "sparse_embedding",
    "index_type": "SPARSE_INVERTED_INDEX",
    "metric_type": "IP",
    "params": {
      "drop_ratio_build": 0.0
    }
  }
}