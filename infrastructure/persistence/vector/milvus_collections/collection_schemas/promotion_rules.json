{
  "collection_name": "doc_promotion_rules",
  "description": "促销规则知识库 - 各类促销活动的规则与条件说明",
  "fields": [
    {
      "name": "id",
      "data_type": "INT64",
      "is_primary": true,
      "auto_id": true,
      "description": "主键，自增ID"
    },
    {
      "name": "promotion_id",
      "data_type": "VARCHAR",
      "max_length": 32,
      "nullable": true,
      "description": "促销活动唯一ID"
    },
    {
      "name": "promotion_name",
      "data_type": "VARCHAR",
      "max_length": 100,
      "nullable": true,
      "description": "促销活动名称（如2024春节大促、满300减50、新人专享券）"
    },
    {
      "name": "promotion_type",
      "data_type": "VARCHAR",
      "max_length": 50,
      "nullable": true,
      "description": "促销类型（discount/coupon/gift/bundle/flash_sale）"
    },
    {
      "name": "category",
      "data_type": "VARCHAR",
      "max_length": 50,
      "nullable": true,
      "description": "促销分类（全场/品类/单品）"
    },
    {
      "name": "target_users",
      "data_type": "VARCHAR",
      "max_length": 200,
      "nullable": true,
      "description": "目标用户群体（如新用户、会员、全部用户）"
    },
    {
      "name": "status",
      "data_type": "VARCHAR",
      "max_length": 20,
      "nullable": true,
      "description": "促销状态（upcoming/active/ended）"
    },
    {
      "name": "start_time",
      "data_type": "INT64",
      "nullable": true,
      "description": "促销开始时间（Unix时间戳）"
    },
    {
      "name": "end_time",
      "data_type": "INT64",
      "nullable": true,
      "description": "促销结束时间（Unix时间戳）"
    },
    {
      "name": "content",
      "data_type": "VARCHAR",
      "max_length": 4000,
      "description": "促销规则详细内容文本，用于向量检索"
    },
    {
      "name": "embedding",
      "data_type": "FLOAT_VECTOR",
      "dim": 1024,
      "description": "稠密向量，用于语义检索"
    },
    {
      "name": "sparse_embedding",
      "data_type": "SPARSE_FLOAT_VECTOR",
      "description": "稀疏向量，用于BM25关键词检索"
    },
    {
      "name": "metadata",
      "data_type": "JSON",
      "nullable": true,
      "description": "扩展元数据（备用字段）"
    }
  ],
  "enable_dynamic_field": true,
  "index": {
    "field_name": "embedding",
    "index_type": "HNSW",
    "metric_type": "COSINE",
    "params": {
      "M": 16,
      "efConstruction": 200
    }
  },
  "sparse_index": {
    "field_name": "sparse_embedding",
    "index_type": "SPARSE_INVERTED_INDEX",
    "metric_type": "BM25",
    "params": {
      "inverted_index_algo": "DAAT_MAXSCORE",
      "bm25_k1": 1.2,
      "bm25_b": 0.75
    }
  }
}
