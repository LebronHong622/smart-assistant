{
  "collection_name": "doc_after_sales_policy",
  "description": "售后规则知识库 - 退换货政策、常见问题与保修规则",
  "fields": [
    {
      "name": "id",
      "data_type": "INT64",
      "is_primary": true,
      "auto_id": true,
      "description": "主键，自增ID"
    },
    {
      "name": "policy_id",
      "data_type": "VARCHAR",
      "max_length": 32,
      "nullable": true,
      "description": "政策唯一ID"
    },
    {
      "name": "policy_code",
      "data_type": "VARCHAR",
      "max_length": 50,
      "nullable": true,
      "description": "政策编码（如RETURN-001、WARRANTY-PHONE）"
    },
    {
      "name": "policy_name",
      "data_type": "VARCHAR",
      "max_length": 100,
      "nullable": true,
      "description": "政策名称（如7天无理由退换货、手机保修政策、配件售后规则）"
    },
    {
      "name": "policy_type",
      "data_type": "VARCHAR",
      "max_length": 50,
      "nullable": true,
      "description": "政策类型（return_policy/warranty/faq/support_rule）"
    },
    {
      "name": "category",
      "data_type": "VARCHAR",
      "max_length": 50,
      "nullable": true,
      "description": "适用品类（手机/电脑/穿戴/配件/全场）"
    },
    {
      "name": "is_active",
      "data_type": "BOOL",
      "nullable": true,
      "description": "政策是否生效"
    },
    {
      "name": "effective_date",
      "data_type": "INT64",
      "nullable": true,
      "description": "政策生效日期（Unix时间戳）"
    },
    {
      "name": "expiry_date",
      "data_type": "INT64",
      "nullable": true,
      "description": "政策失效日期（Unix时间戳）"
    },
    {
      "name": "content",
      "data_type": "VARCHAR",
      "max_length": 4000,
      "description": "政策详细内容文本，用于向量检索"
    },
    {
      "name": "embedding",
      "data_type": "FLOAT_VECTOR",
      "dim": 1024,
      "description": "稠密向量，用于语义检索"
    },
    {
      "name": "sparse_embedding",
      "data_type": "SPARSE_FLOAT_VECTOR",
      "description": "稀疏向量，用于BM25关键词检索"
    },
    {
      "name": "metadata",
      "data_type": "JSON",
      "nullable": true,
      "description": "扩展元数据（备用字段）"
    }
  ],
  "enable_dynamic_field": true,
  "index": {
    "field_name": "embedding",
    "index_type": "HNSW",
    "metric_type": "COSINE",
    "params": {
      "M": 16,
      "efConstruction": 200
    }
  },
  "sparse_index": {
    "field_name": "sparse_embedding",
    "index_type": "SPARSE_INVERTED_INDEX",
    "metric_type": "BM25",
    "params": {
      "inverted_index_algo": "DAAT_MAXSCORE",
      "bm25_k1": 1.2,
      "bm25_b": 0.75
    }
  }
}
