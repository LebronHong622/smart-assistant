DEEPSEEK_API_KEY=sk-your_deepseek_api_key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 日志配置
LOG_LEVEL=INFO  # 可选值: DEBUG/INFO/WARNING/ERROR/CRITICAL

# 天气API密钥
AMAP_API_KEY=your_amap_api_key

# 存储后端配置
STORAGE_BACKEND=in_memory  # 可选值: in_memory/redis

# 组件预加载配置
PRELOAD_COMPONENTS=redis,milvus,postgres  # 预加载的底层组件，逗号分隔，可选值: redis, milvus, postgres
FAIL_FAST_ON_INIT_ERROR=True  # 组件初始化失败时是否直接终止启动

# Redis 连接配置（当 STORAGE_BACKEND=redis 时需要配置）
# REDIS_URL=redis://localhost:6379/0
# 或单独配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=you_redis_password
# REDIS_SOCKET_TIMEOUT=5
# REDIS_SOCKET_CONNECT_TIMEOUT=5
# REDIS_RETRY_ON_TIMEOUT=True
# REDIS_MAX_CONNECTIONS=10

# Milvus 向量数据库配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION_NAME=document_embeddings
MILVUS_DIMENSION=1536
MILVUS_METRIC_TYPE=L2
MILVUS_INDEX_TYPE=IVF_FLAT
MILVUS_N_LIST=1024

# DashScope API 配置（阿里千文 Embeddings）
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
DASHSCOPE_EMBEDDING_DIM=768

# PostgreSQL 数据库配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=multitask_qa
POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
